# NextAuth Configuration
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
# Create at: https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# LinkedIn OAuth
# Create at: https://www.linkedin.com/developers/apps
# Authorized redirect URL: http://localhost:3000/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Stripe Payments
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Gumroad Payments
# Create a product at: https://app.gumroad.com/products/new
# Enable "Generate a unique license key per sale" on the product
GUMROAD_PRODUCT_ID=your-product-permalink
NEXT_PUBLIC_GUMROAD_URL=https://gumroad.com/l/your-product-permalink
